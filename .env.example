# ============================================
# 🏥 CLINICBOT PRO - Variables de Entorno
# ============================================
# Copia este archivo y renómbralo a .env
# Luego llena los valores con TUS datos reales
# NUNCA subas el archivo .env a GitHub
# ============================================

# --- Base de datos (Supabase) ---
SUPABASE_URL=tu_url_de_supabase_aqui
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_KEY=tu_service_key_aqui
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# --- Inteligencia Artificial (Groq) ---
GROQ_API_KEY=tu_api_key_de_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui
TELEGRAM_WEBHOOK_URL=https://tu-dominio.com/webhook/telegram

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=tu_contraseña_segura_aqui
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# --- Backend API ---
API_PORT=3000
API_SECRET_KEY=tu_clave_secreta_para_jwt_aqui
NODE_ENV=development

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=tu_contraseña_redis_aqui

# --- Seguridad ---
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15